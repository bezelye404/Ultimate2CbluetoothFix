# ============================================
# MAXIMUM SECURITY .gitignore
# ============================================

# Build outputs (may contain paths)
bin/
obj/
publish/
out/
build/
release/
debug/
x64/
x86/

# Debug symbols (contain full file paths)
*.pdb
*.dbg
*.dmp

# IDE and Editor files
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln.docstates
*.rsuser
*.userprefs
.project
.settings/

# Logs (may contain system/user info)
*.log
*.txt.log
crash.log
error.log

# Cache and temp
*.cache
*.tmp
*.temp
*~
.cache/
__pycache__/

# OS generated files
Thumbs.db
ehthumbs.db
.DS_Store
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Backup files
*.bak
*.backup
*.old
*.orig

# NuGet
packages/
*.nupkg
.nuget/

# Local settings (may contain secrets)
*.local
*.env
.env
appsettings.*.json
secrets.json
launchSettings.json

# Test results
TestResults/
*.trx

# Coverage
coverage/
*.coverage
*.coveragexml

# Archives
*.zip
*.7z
*.rar
*.tar.gz

# Executables
*.exe
*.dll
*.so
*.dylib
