<Window x:Class="BitDoFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="8BitDo Fixer" Height="600" Width="900"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Status Cards -->
            <RowDefinition Height="*"/>    <!-- Logs -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
            <DockPanel>
                <materialDesign:PackIcon Kind="GamepadVariant" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="8BitDo Kontrolcü Düzeltici"/>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Status Dashboard -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Connection Status -->
            <materialDesign:Card Margin="0,0,10,0" Padding="20" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="BAĞLANTI DURUMU" FontSize="12" FontWeight="Bold" Opacity="0.8" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <materialDesign:PackIcon Kind="BluetoothConnect" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtRemapperStatus" Text="Taranıyor..." FontSize="26" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtDeviceInfo" Text="D-Input Cihazı Bekleniyor..." FontSize="14" Opacity="0.6" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Card 2: Battery -->
            <materialDesign:Card Grid.Column="1" Margin="10,0,0,0" Padding="20" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="PİL SEVİYESİ" FontSize="12" FontWeight="Bold" Opacity="0.8" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Battery Icon/Gauge -->
                        <Grid Width="60" Height="60">
                             <ProgressBar x:Name="BatteryProgress" Style="{DynamicResource MaterialDesignCircularProgressBar}"
                                          Value="0"
                                          Maximum="100" Width="60" Height="60"/>
                             <materialDesign:PackIcon Kind="BatteryCharging"
                                                      Width="28" Height="28"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock x:Name="TxtBatteryLevel" Text="--%" FontSize="32" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtBatteryDevice" Text="Cihaz Bağlı Değil" FontSize="14" Opacity="0.6" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Logs Console -->
        <Border Grid.Row="2" Margin="20,0,20,10" Background="#1E1E1E" CornerRadius="8" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
            <Grid>
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Margin="5">
                    <TextBox x:Name="TxtLogs" Margin="10" IsReadOnly="True" 
                             TextWrapping="Wrap" BorderThickness="0" FontFamily="Consolas" FontSize="13"
                             Foreground="#A9B7C6" Background="Transparent"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Actions Footer -->
        <Grid Grid.Row="3" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="v0.0.1 • github.com/bezelye404" VerticalAlignment="Center" Opacity="0.5" FontStyle="Italic"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnStop" Click="BtnStop_Click" Style="{DynamicResource MaterialDesignOutlinedButton}" Content="DURDUR" Margin="0,0,10,0" IsEnabled="False" Width="120"/>
                <Button x:Name="BtnStart" Click="BtnStart_Click" Style="{DynamicResource MaterialDesignRaisedButton}" Content="BAŞLAT" Width="120"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
