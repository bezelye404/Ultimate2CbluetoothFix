<Application x:Class="BitDoFixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Teal" SecondaryColor="Amber" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Explicit accent colors: guaranteed to render regardless of theme resource resolution -->
            <SolidColorBrush x:Key="AccentTealBrush" Color="#2DD9C2"/>
            <SolidColorBrush x:Key="AccentTealDarkBrush" Color="#0D4A43"/>
            <SolidColorBrush x:Key="AccentAmberBrush" Color="#FFC94A"/>
            <SolidColorBrush x:Key="HeaderTextBrush" Color="#F2FFFC"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="#23282A"/>
            <SolidColorBrush x:Key="PageBgBrush" Color="#161A1B"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
